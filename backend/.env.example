# AI Image Gen Backend Configuration
# Copy this file to .env and fill in your actual values

APP_NAME=AI Image Gen
APP_VERSION=0.1.0
DEBUG=True
API_PREFIX=/api/v1

# Proxy API (中转站)
PROXY_API_URL=https://api.bondai.cc/v1
PROXY_API_KEY=YOUR_ACTUAL_API_KEY_HERE

# Database (future)
DATABASE_URL=sqlite:///./ai_image_gen.db

# Redis (future)
REDIS_URL=redis://localhost:6379/0
